alert icmp any any -> any any (msg:"ICMP Ping detecte !"; sid:1000001; rev:1;)
# Détection scan Nmap
alert tcp any any -> 192.168.10.2 any (msg:"Scan Nmap detecte !"; flags:S; threshold:type threshold, track by_src, count 20, seconds 3; sid:1000002; rev:1;)

# Détection SSH Brute Force
alert tcp any any -> 192.168.10.2 22 (msg:"SSH Brute Force detecte !"; threshold:type threshold, track by_src, count 5, seconds 10; sid:1000003; rev:1;)

# Détection ping flood
alert icmp any any -> 192.168.10.2 any (msg:"Ping Flood detecte !"; threshold:type threshold, track by_src, count 50, seconds 1; sid:1000004; rev:1;)
